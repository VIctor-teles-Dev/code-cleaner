# ==============================================================================
# code-cleaner — variáveis de ambiente (exemplo)
#
# Copie para .env e preencha com valores reais (.env é gitignored).
# Em produção (k8s) esses valores vivem em Secrets — veja infra/k8s/*sealed-secret*.yaml
# e infra/README.md para como gerar/re-selar com kubeseal.
# ==============================================================================

# --- Postgres  (Secret: postgres-credentials) --------------------------------
POSTGRES_USER=ccl
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=ccl

# --- backend-api -------------------------------------------------------------
PORT=8080
DATABASE_URL=postgres://ccl:troque-esta-senha@postgres:5432/ccl?sslmode=disable
# Token do POST /posts (Secret: blog-admin-token). Vazio => publicação desabilitada.
BLOG_ADMIN_TOKEN=troque-este-token
# Notificação de contato por email (Secret: smtp-credentials). Opcional:
# sem SMTP_HOST/CONTACT_TO a mensagem só é gravada no banco. Gmail: porta 587 + app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=voce@gmail.com
SMTP_PASSWORD=app-password-de-16-chars
CONTACT_FROM=voce@gmail.com
CONTACT_TO=voce@gmail.com

# --- web-app  (proxy same-origin para o backend interno) ---------------------
BACKEND_URL=http://backend-api:8080
# Admin do blog (/admin): a UI é protegida por senha; os proxies /api/admin/*
# reusam o BLOG_ADMIN_TOKEN acima p/ falar com a API (o token nunca vai ao browser).
# ADMIN_PASSWORD_HASH: hash scrypt da senha. Gere com:
#   cd apps/web-app && node scripts/hash-password.mjs 'sua-senha-forte'
# SESSION_SECRET: string aleatória p/ assinar o cookie de sessão. Gere com:
#   openssl rand -base64 32
# Vazios => login do admin desabilitado.
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
